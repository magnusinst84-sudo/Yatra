# Yatra — environment variable reference
# Every var the app needs must be listed here with NO real value.
# Copy to .env (backend) / .env.local (frontend) and fill in locally — never commit the filled version.

GEMINI_API_KEY=

# ---------------------------------------------------------------------------
# OpenAI — single provider for agent, embeddings, image generation
# ---------------------------------------------------------------------------
# Single-key mode (default — use this until pooling approval below is confirmed on record):
OPENAI_API_KEY=

# Pooled mode (B1-owned, see backend/clients.py). Only use if organizer approval
# for cross-key pooling is actually documented (date + who confirmed) — see
# Session Handoff Summary Section 7. If unconfirmed, leave these unset and use
# OPENAI_API_KEY above only.
OPENAI_API_KEY_B1=
OPENAI_API_KEY_B2=
OPENAI_API_KEY_FRONTEND=
OPENAI_API_KEY_RAG=

# ---------------------------------------------------------------------------
# RAG — Chroma vector store (RAG owner)
# ---------------------------------------------------------------------------
CHROMA_PERSIST_DIR=./backend/rag/chroma_store

# ---------------------------------------------------------------------------
# MongoDB Atlas (B1 — schema/writes; B2 — connection setup, confirm split)
# ---------------------------------------------------------------------------
MONGODB_URI=

# ---------------------------------------------------------------------------
# Firebase Auth (B1)
# ---------------------------------------------------------------------------
# NOTE: naming mismatch across docs — TRD and Backend Schema use
# FIREBASE_ADMIN_SDK_JSON (single var, full service account JSON as a string).
# Architecture doc instead lists FIREBASE_PROJECT_ID + FIREBASE_ADMIN_CREDENTIALS
# (two vars). Going with FIREBASE_ADMIN_SDK_JSON since 2 of 3 docs agree —
# confirm this matches whatever firebase_verify.py actually reads before day 4.
FIREBASE_ADMIN_SDK_JSON=

# ---------------------------------------------------------------------------
# Frontend — backend URL + Firebase client config
# ---------------------------------------------------------------------------
VITE_API_URL=
# Public by design (client-side Firebase config, not a secret):
VITE_FIREBASE_CONFIG=
